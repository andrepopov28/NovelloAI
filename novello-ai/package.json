{
  "name": "novello-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "analyze": "ANALYZE=true next build",
    "lint": "eslint",
    "download-voices": "node scripts/downloadVoices.js",
    "voice:smoke": "tsx scripts/smokeTestVoices.ts",
    "uat:up": "docker compose -f docker-compose.uat.yml up -d",
    "uat:down": "docker compose -f docker-compose.uat.yml down -v",
    "uat:seed": "tsx uat/scripts/seed.ts",
    "uat:headless": "vitest run --dir uat/headless",
    "uat:headed": "playwright test -c uat/headed/playwright.config.ts",
    "uat:all": "pnpm uat:up && pnpm uat:seed && pnpm uat:headless && pnpm uat:headed && pnpm uat:down"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.30",
    "@tiptap/extension-bubble-menu": "^3.19.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-mention": "^3.19.0",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/extension-text-align": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "@tiptap/suggestion": "^3.19.0",
    "@types/dompurify": "^3.0.5",
    "@types/recharts": "^1.8.29",
    "ai": "^6.0.86",
    "date-fns": "^4.1.0",
    "docx": "^9.5.2",
    "dompurify": "^3.3.1",
    "epub-gen-memory": "^1.1.2",
    "file-saver": "^2.0.5",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.1.0",
    "lucide-react": "^0.564.0",
    "mammoth": "^1.11.0",
    "next": "^15.1.0",
    "nuqs": "^2.8.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "undici": "^7.24.6"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@next/bundle-analyzer": "^15.0.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "^15.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
