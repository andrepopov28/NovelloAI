rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Per-user data: playback positions, bookmarks ──────────────
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Projects: only the owner can read/write ───────────────────
    match /projects/{projectId} {
      allow get, list:      if request.auth != null && resource.data.userId == request.auth.uid;
      allow create:         if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ── Chapters: scoped to owner via projectId cross-reference ───
    // NOTE: Firestore rules cannot do cross-doc lookups easily,
    // so we enforce write ownership via userId field on the document.
    match /chapters/{chapterId} {
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ── Entities: owner-scoped ────────────────────────────────────
    match /entities/{entityId} {
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ── Series: owner-scoped ──────────────────────────────────────
    match /series/{seriesId} {
      allow read:   if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ── Exports (audiobooks, PDFs): owner only ────────────────────
    match /exports/{exportId} {
      allow get, list:      if request.auth != null && resource.data.userId == request.auth.uid;
      allow create:         if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ── Server-side only (Admin SDK bypasses these rules) ─────────
    // voice_catalog, continuityReports, persona_settings are written
    // exclusively via the Admin SDK in API routes — no client access needed.
    match /voice_catalog/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }
  }
}
